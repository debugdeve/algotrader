{
  "name": "algotrader-backend",
  "version": "1.0.0",
  "description": "Fyers Multiplexed Aggregator for AlgoTrader Pro",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src/**/*.ts --exec ts-node --files src/index.ts",
    "build": "tsc",
    "test:auth": "ts-node src/scripts/test-auth.ts",
    "test:key-manager": "ts-node src/scripts/test-key-manager.ts"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
