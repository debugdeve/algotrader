    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "otplib": "^12.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
